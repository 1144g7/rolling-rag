{
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "description": "全局详细摘要，长度与信息量匹配，用户视角（用户…AI…），实体密集"
    },
    "conclusion": {
      "description": "整场对话最终结论，一句话。或 null",
      "type": ["string", "null"]
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "叙事段名 3-15字"
          },
          "msg_span": {
            "type": "array",
            "items": {"type": "integer"},
            "minItems": 2,
            "maxItems": 2,
            "description": "[起始消息号, 结束消息号] 1-based"
          },
          "summary": {
            "type": "string",
            "description": "150-300字实体密集摘要"
          }
        },
        "required": ["name", "msg_span", "summary"]
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "integer",
            "description": "segments 数组下标 0-based"
          },
          "to": {
            "type": "integer",
            "description": "segments 数组下标 0-based"
          },
          "type": {
            "type": "string",
            "description": "关系类型：演进|佐证|因果|应用|对照|前提|同源，或不匹配的自填"
          }
        },
        "required": ["from", "to", "type"]
      }
    }
  },
  "required": ["summary", "segments", "relations"]
}
