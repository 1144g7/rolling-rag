{
  "type": "object",
  "properties": {
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "叙事段名 3-15字"
          },
          "msg_span": {
            "type": "array",
            "items": {"type": ["integer", "null"]},
            "minItems": 2,
            "maxItems": 2,
            "description": "[起始消息号, 结束消息号] 1-based。未完成段结束号填 null"
          },
          "summary": {
            "type": "string",
            "description": "150-300字实体密集摘要"
          },
          "complete": {
            "type": "boolean",
            "description": "该段是否已收尾。最后一个 segment 允许 false"
          }
        },
        "required": ["name", "msg_span", "summary", "complete"]
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "integer",
            "description": "segments 数组下标 0-based"
          },
          "to": {
            "type": "integer",
            "description": "segments 数组下标 0-based"
          },
          "type": {
            "type": "string",
            "description": "关系类型：演进|佐证|因果|应用|对照|前提|同源，或不匹配的自填"
          }
        },
        "required": ["from", "to", "type"]
      }
    }
  },
  "required": ["segments", "relations"]
}
