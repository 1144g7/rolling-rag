{
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "description": "全局详细摘要，长度与段数和信息量匹配，用户视角（用户…AI…），实体密集"
    },
    "conclusion": {
      "description": "整场对话最终结论，一句话。或 null",
      "type": ["string", "null"]
    },
    "extra_relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "integer",
            "description": "segments 数组下标 0-based"
          },
          "to": {
            "type": "integer",
            "description": "segments 数组下标 0-based"
          },
          "type": {
            "type": "string",
            "description": "关系类型：演进|佐证|因果|应用|对照|前提|同源，或不匹配的自填"
          }
        },
        "required": ["from", "to", "type"]
      }
    }
  },
  "required": ["summary", "conclusion", "extra_relations"]
}
